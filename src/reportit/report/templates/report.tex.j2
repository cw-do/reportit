\documentclass[11pt]{article}
\usepackage[utf8]{inputenc}
\usepackage[T1]{fontenc}
\usepackage{textcomp}
\usepackage[margin=1in]{geometry}
\usepackage{graphicx}
\usepackage{booktabs}
\usepackage{float}
\usepackage{amsmath}
\usepackage{caption}
\usepackage[hidelinks]{hyperref}
\usepackage{longtable}
\usepackage{pdflscape}

\title{<< title >>}
\author{Generated by \texttt{reportit}}
\date{<< generated_at >>}

\begin{document}
\maketitle

\begin{abstract}
<< overview >>
\end{abstract}

<% if science_goals %>
\section*{Science Goals}
\begin{itemize}
<% for g in science_goals %>  \item << g >>
<% endfor %>\end{itemize}
<% endif %>

<% if catalog_table %>
\section{Sample Summary}
<< render_table(catalog_table) >>
<% endif %>

\section{Results by Sample Group}
<% for gr in group_reports %>
\subsection{<< gr.title >>}
<% if gr.description %><< gr.description >>

<% endif %><% if gr.observations %><< gr.observations >>

<% endif %>
<% for fig in gr.figures %>
\begin{figure}[H]
  \centering
  \includegraphics[width=<< fig.width >>]{<< fig.path >>}
  \caption{<< fig.caption >>}
  \label{<< fig.label >>}
\end{figure}
<% endfor %>
<% if mode == 'comprehensive' and gr.table %>
<< render_table(gr.table) >>
<% endif %>
<% endfor %>

<% if sas_summary %>
\section{Model-Based Fitting (sasmodels)}
This section reports automated, AI-driven fitting of representative curves to
SasView/sasmodels models: a reasoning agent selected candidate models and
parameter setups from the curve shape and experiment context, each was fit with
\texttt{bumps}, and a critic agent (including visual inspection of the fit)
accepted or rejected it. Both successful and unsuccessful outcomes are reported.

<< render_table(sas_summary.table) >>

<% for s in sas_sections %>
\subsection{<< s.title >>}
\textbf{Selected model:} << s.model >> \quad \textbf{Status:} << s.status >> <% if s.chisq != '—' %>\quad ($\chi^2_\nu$ = << s.chisq >>)<% endif %>

<% if s.rationale %>\emph{Model choice:} << s.rationale >>

<% endif %>
<% if s.figure %>
\begin{figure}[H]
  \centering
  \includegraphics[width=<< s.figure.width >>]{<< s.figure.path >>}
  \caption{<< s.figure.caption >>}
  \label{<< s.figure.label >>}
\end{figure}
<% endif %>
<% if s.params_table %><< render_table(s.params_table) >>
<% endif %>
<% if s.critique %>\emph{Critic assessment:} << s.critique >>

<% endif %>
<% if s.member_table %><< render_table(s.member_table) >>
<% endif %>
<% if s.trend_figure %>
\begin{figure}[H]
  \centering
  \includegraphics[width=<< s.trend_figure.width >>]{<< s.trend_figure.path >>}
  \caption{<< s.trend_figure.caption >>}
  \label{<< s.trend_figure.label >>}
\end{figure}
<% endif %>
<% if s.attempts %>\emph{Models tried:} << s.attempts >>.

<% endif %>
<% endfor %>
<% endif %>

<% if hypothesis_checks %>
\section{Hypothesis Assessment}
\begin{longtable}{p{6cm} l l p{4cm}}
\toprule
\textbf{Hypothesis} & \textbf{Verdict} & \textbf{Confidence} & \textbf{Evidence} \\
\midrule
\endhead
<% for hc in hypothesis_checks %><< hc.hypothesis >> & << hc.verdict >> & << hc.confidence >> & << hc.evidence >> \\
\addlinespace
<% endfor %>\bottomrule
\end{longtable}
<% endif %>

<% if discussion %>
\section{Discussion}
<< discussion >>
<% endif %>

<% if caveats %>
\section{Methods \& Caveats}
\begin{itemize}
<% for c in caveats %>  \item << c >>
<% endfor %>\end{itemize}
<% endif %>

<% if appendix_tables %>
\appendix
<% for a in appendix_tables %>
\section{<< a.section_title >>}
<< render_table(a.table) >>
<% endfor %>
<% endif %>

\end{document}
